# Copie para .env.local e preencha (o .env.local nunca vai pro GitHub).
# Na Vercel: Settings → Environment Variables → adicionar as 3.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# TMDB → Settings → API (aceita a API Key v3 OU o Read Access Token v4)
TMDB_API_KEY=sua-tmdb-key
